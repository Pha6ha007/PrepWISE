# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Provider (Groq or OpenAI)
# Groq API (FREE for development) - https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API (альтернатива) - https://platform.openai.com
OPENAI_API_KEY=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=confide-knowledge

# ElevenLabs
ELEVENLABS_API_KEY=

# Dodo Payments (Merchant of Record)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_PRO_ID=
DODO_PRODUCT_PREMIUM_ID=
NEXT_PUBLIC_DODO_PRODUCT_PRO_ID=
NEXT_PUBLIC_DODO_PRODUCT_PREMIUM_ID=

# Resend (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@confide.app

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Jobs
# Secret for protecting cron endpoints from unauthorized access
# Generate with: openssl rand -base64 32
CRON_SECRET=
