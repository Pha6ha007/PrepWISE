// Confide — Prisma Schema
// Based on CLAUDE.md database architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USERS & PROFILES
// ============================================

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique
  createdAt       DateTime @default(now()) @map("created_at")
  plan            String   @default("free") // free | pro | premium
  voiceId         String?  @map("voice_id")
  companionName   String   @default("") @map("companion_name")
  companionGender String?  @map("companion_gender") // male | female
  language        String   @default("en") // en | ru

  // User profile fields
  preferredName   String?  @map("preferred_name") // как обращаться
  ageGroup        String?  @map("age_group") // 18-25 | 26-35 | 36-45 | 45+
  userGender      String?  @map("user_gender") // male | female | not_specified

  profile        UserProfile?
  sessions       Session[]
  messages       Message[]
  journalEntries JournalEntry[]
  diaries        Diary[]
  subscription   Subscription?
  moodEntries    MoodEntry[]
  goals          Goal[]
  homework       Homework[]

  @@map("users")
}

model UserProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  communicationStyle Json?   @map("communication_style") // стиль общения, длина, юмор
  emotionalProfile  Json?    @map("emotional_profile") // триггеры, болевые точки
  lifeContext       Json?    @map("life_context") // ключевые люди, работа
  patterns          Json?    // повторяющиеся сценарии
  progress          Json?    // что улучшилось
  whatWorked        Json?    @map("what_worked") // что давало результат
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ============================================
// SESSIONS & MESSAGES
// ============================================

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  agentType   String    @map("agent_type") // anxiety | family | trauma | etc
  createdAt   DateTime  @default(now()) @map("created_at")
  endedAt     DateTime? @map("ended_at")
  summary     String?   // GPT summary 5-7 фактов
  moodScore   Int?      @map("mood_score") // 1-10 настроение пользователя (deprecated, use MoodEntry)
  moodBefore  Int?      @map("mood_before") // 1-7 настроение до сессии
  moodAfter   Int?      @map("mood_after") // 1-7 настроение после сессии

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  moodEntries MoodEntry[]

  @@map("sessions")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   // user | assistant
  content   String   @db.Text
  audioUrl  String?  @map("audio_url")
  createdAt DateTime @default(now()) @map("created_at")
  isCrisis  Boolean  @default(false) @map("is_crisis") // флаг Crisis Agent

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  journalEntries JournalEntry[]

  @@map("messages")
}

// ============================================
// JOURNAL
// ============================================

model JournalEntry {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  content         String   @db.Text
  insight         String?  @db.Text
  sourceMessageId String?  @map("source_message_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMessage Message? @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@map("journal_entries")
}

// ============================================
// SUBSCRIPTIONS (Paddle)
// ============================================

model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  paddleCustomerId     String    @map("paddle_customer_id")
  paddleSubscriptionId String    @map("paddle_subscription_id")
  plan                 String    // free | pro | premium
  status               String    // active | cancelled | expired
  expiresAt            DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// KNOWLEDGE BASE (RAG)
// ============================================

model KnowledgeBase {
  id          String  @id @default(uuid()) @db.Uuid
  sourceTitle String  @map("source_title")
  author      String
  namespace   String  // anxiety | family | trauma | crisis
  chunkIndex  Int     @map("chunk_index")
  pineconeId  String  @map("pinecone_id")

  @@map("knowledge_base")
}

// ============================================
// DIARY (PDF библиотека)
// ============================================

model Diary {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  month      Int      // 1-12
  year       Int      // 2026, 2027, etc
  storageUrl String   @map("storage_url") // Supabase Storage URL
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year]) // Один дневник на пользователя в месяц
  @@map("diaries")
}

// ============================================
// MOOD TRACKING
// ============================================

model MoodEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sessionId String?  @map("session_id") @db.Uuid
  type      String   // "before" | "after"
  score     Int      // 1-7
  reasons   Json     @default("[]") // ["work", "family", "sleep"]
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("mood_entries")
}

// ============================================
// GOALS & PROGRESS
// ============================================

model Goal {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  category    String      // anxiety | relationships | selfesteem | sleep | stress | communication | boundaries | grief
  title       String
  description String?     @db.Text
  progress    Int         @default(0) // 0-100
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]

  @@map("goals")
}

model Milestone {
  id          String    @id @default(uuid()) @db.Uuid
  goalId      String    @map("goal_id") @db.Uuid
  text        String
  done        Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  order       Int       @default(0)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Homework {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  title       String
  description String    @db.Text
  agent       String    // "Anxiety" | "Family" | "Trauma" | etc.
  dueDate     DateTime  @map("due_date")
  done        Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("homework")
}
