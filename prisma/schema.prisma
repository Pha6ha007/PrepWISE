// Confide — Prisma Schema
// Based on CLAUDE.md database architecture

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ============================================
// USERS & PROFILES
// ============================================

model User {
  id              String   @id @default(uuid()) @db.Uuid
  email           String   @unique
  createdAt       DateTime @default(now()) @map("created_at")
  plan            String   @default("free") // free | pro | premium
  voiceId         String?  @map("voice_id")
  companionName   String   @default("") @map("companion_name")
  companionGender String?  @map("companion_gender") // male | female
  language        String   @default("en") // en | ru

  // User profile fields
  preferredName   String?  @map("preferred_name") // как обращаться
  ageGroup        String?  @map("age_group") // 18-25 | 26-35 | 36-45 | 45+
  userGender      String?  @map("user_gender") // male | female | not_specified

  profile        UserProfile?
  sessions       Session[]
  messages       Message[]
  journalEntries JournalEntry[]
  diaries        Diary[]
  subscription   Subscription?
  moodEntries       MoodEntry[]
  goals             Goal[]
  homework          Homework[]
  proactiveMessages ProactiveMessage[]
  allianceSurveys   AllianceSurvey[]
  safetyLogs        SafetyLog[]

  // Free trial (7-day, no credit card)
  trialStartDate DateTime? @map("trial_start_date")
  trialEndDate   DateTime? @map("trial_end_date")

  // Prepwise GMAT relations
  gmatSessions   GmatSession[]
  topicProgress  TopicProgress[]
  errorLogs      ErrorLog[]
  mockTests       MockTest[]
  studyJournal    StudyJournalEntry[]
  gmatProfile    Json?          @map("gmat_profile") // GmatLearnerProfile from Memory Agent

  @@map("users")
}

model UserProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  communicationStyle Json?   @map("communication_style") // стиль общения, длина, юмор
  emotionalProfile  Json?    @map("emotional_profile") // триггеры, болевые точки
  lifeContext       Json?    @map("life_context") // ключевые люди, работа
  patterns          Json?    // повторяющиеся сценарии
  progress          Json?    // что улучшилось
  whatWorked        Json?    @map("what_worked") // что давало результат

  // Memory Agent Upgrade (март 2026) — автоматический анализ стиля
  styleMetrics      Json     @default("{}") @map("style_metrics") // avgMessageLength, usesEmoji, emotionalOpenness, etc
  whatDidntWork     Json     @default("[]") @map("what_didnt_work") // что НЕ сработало
  emotionalAnchors  Json     @default("[]") @map("emotional_anchors") // метафоры/фразы которые зацепили
  topicConnections  Json     @default("{}") @map("topic_connections") // связи между темами

  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ============================================
// SESSIONS & MESSAGES
// ============================================

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  agentType   String    @map("agent_type") // anxiety | family | trauma | etc
  createdAt   DateTime  @default(now()) @map("created_at")
  endedAt     DateTime? @map("ended_at")
  summary     String?   // GPT summary 5-7 фактов
  moodScore   Int?      @map("mood_score") // 1-10 настроение пользователя (deprecated, use MoodEntry)
  moodBefore  Int?      @map("mood_before") // 1-7 настроение до сессии
  moodAfter   Int?      @map("mood_after") // 1-7 настроение после сессии

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  moodEntries MoodEntry[]

  @@map("sessions")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   // user | assistant
  content   String   @db.Text
  audioUrl  String?  @map("audio_url")
  createdAt DateTime @default(now()) @map("created_at")
  isCrisis  Boolean  @default(false) @map("is_crisis") // флаг Crisis Agent

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  journalEntries JournalEntry[]

  @@map("messages")
}

// ============================================
// JOURNAL
// ============================================

model JournalEntry {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  content         String   @db.Text
  insight         String?  @db.Text
  sourceMessageId String?  @map("source_message_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMessage Message? @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@map("journal_entries")
}

// ============================================
// SUBSCRIPTIONS (Dodo Payments)
// ============================================

model Subscription {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  paddleCustomerId       String    @map("paddle_customer_id")
  paddleSubscriptionId   String    @map("paddle_subscription_id")
  plan                   String    // free | starter | pro | intensive
  status                 String    // active | cancelled | on_hold | expired | trialing | past_due
  trialEndsAt            DateTime? @map("trial_ends_at")
  expiresAt              DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// KNOWLEDGE BASE (RAG)
// ============================================

model KnowledgeBase {
  id          String  @id @default(uuid()) @db.Uuid
  sourceTitle String  @map("source_title")
  author      String
  namespace   String  // anxiety | family | trauma | crisis
  chunkIndex  Int     @map("chunk_index")
  pineconeId  String  @map("pinecone_id")

  @@map("knowledge_base")
}

// ============================================
// DIARY (PDF библиотека)
// ============================================

model Diary {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  month      Int      // 1-12
  year       Int      // 2026, 2027, etc
  title      String   @default("") // "March 2026 — Your Journey"
  status     String   @default("generating") // generating | ready | error
  storageUrl String?  @map("storage_url") // Supabase Storage URL (nullable пока генерируется)
  errorMessage String? @map("error_message") @db.Text // Сообщение об ошибке если status = error
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year]) // Один дневник на пользователя в месяц
  @@map("diaries")
}

// ============================================
// MOOD TRACKING
// ============================================

model MoodEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  sessionId String?  @map("session_id") @db.Uuid
  type      String   // "before" | "after"
  score     Int      // 1-7
  reasons   Json     @default("[]") // ["work", "family", "sleep"]
  note      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("mood_entries")
}

// ============================================
// GOALS & PROGRESS
// ============================================

model Goal {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  category    String      // anxiety | relationships | selfesteem | sleep | stress | communication | boundaries | grief
  title       String
  description String?     @db.Text
  progress    Int         @default(0) // 0-100
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]

  @@map("goals")
}

model Milestone {
  id          String    @id @default(uuid()) @db.Uuid
  goalId      String    @map("goal_id") @db.Uuid
  text        String
  done        Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  order       Int       @default(0)

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Homework {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  title       String
  description String    @db.Text
  agent       String    // "Anxiety" | "Family" | "Trauma" | etc.
  dueDate     DateTime  @map("due_date")
  done        Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("homework")
}

// ============================================
// PROACTIVE MESSAGES
// ============================================

model ProactiveMessage {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   // "nudge" | "morning" | "followup" | "milestone" | "exercise"
  content   String   @db.Text
  metadata  Json?    // { reason, sessionId, etc }
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("proactive_messages")
}

// ============================================
// THERAPEUTIC ALLIANCE SURVEY
// ============================================

model AllianceSurvey {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  sessionNumber  Int      @map("session_number") // На какой сессии показан опрос (5, 10, 15...)
  understanding  Int      // 1-5: "Alex понимает меня"
  trust          Int      // 1-5: "Я могу быть честным с Alex"
  helpfulness    Int      // 1-5: "Разговоры помогают мне"
  feedback       String?  @db.Text // Опциональный текстовый отзыв
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alliance_surveys")
}

// ============================================
// SAFETY LOGGING
// ============================================

model SafetyLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  sessionId     String   @map("session_id")
  messageId     String   @map("message_id")
  triggerType   String   @map("trigger_type") // "crisis_adjacent" | "inappropriate" | "boundary_violation" | "medical_advice"
  userMessage   String   @map("user_message") // Только первые 50 символов для контекста
  agentResponse String   @map("agent_response") @db.Text // Первые 200 символов ответа
  severity      String   // "low" | "medium" | "high"
  reviewed      Boolean  @default(false)
  reviewNote    String?  @map("review_note") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("safety_logs")
}

// ============================================
// RATE LIMITING
// ============================================

model RateLimit {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  endpoint    String   // "/api/chat" | "/api/voice" | "/api/tts"
  count       Int      @default(1)
  windowStart DateTime @default(now()) @map("window_start")

  @@unique([userId, endpoint])
  @@index([windowStart]) // для быстрой очистки старых записей
  @@map("rate_limits")
}

// ============================================
// PREPWISE — GMAT SESSIONS
// ============================================

model GmatSession {
  id             String    @id @default(cuid())
  userId         String    @map("user_id") @db.Uuid
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt      DateTime  @default(now()) @map("started_at")
  endedAt        DateTime? @map("ended_at")
  durationMins   Int?      @map("duration_mins")

  agentUsed      String    @map("agent_used") // "quantitative" | "verbal" | "data_insights" | "writing" | "strategy"
  topicsCovered  String[]  @map("topics_covered")
  questionsAsked Int       @default(0) @map("questions_asked")
  correctAnswers Int       @default(0) @map("correct_answers")

  transcript     String?   @db.Text
  memoryUpdated  Boolean   @default(false) @map("memory_updated")

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("gmat_sessions")
}

// ============================================
// PREPWISE — TOPIC PROGRESS
// ============================================

model TopicProgress {
  id              String    @id @default(cuid())
  userId          String    @map("user_id") @db.Uuid
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  section         String    // "quant" | "verbal" | "data-insights" | "awa"
  topic           String    // "algebra" | "critical-reasoning" | etc.
  subtopic        String?

  totalAttempts   Int       @default(0) @map("total_attempts")
  correctAttempts Int       @default(0) @map("correct_attempts")
  accuracy        Float     @default(0.0) // 0.0 - 1.0

  lastPracticed   DateTime? @map("last_practiced")
  masteryLevel    String    @default("not_started") @map("mastery_level") // "not_started" | "learning" | "practicing" | "mastered"

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([userId, section, topic, subtopic])
  @@index([userId])
  @@map("topic_progress")
}

// ============================================
// PREPWISE — ERROR LOG
// ============================================

model ErrorLog {
  id              String   @id @default(cuid())
  userId          String   @map("user_id") @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String?  @map("session_id")

  section         String   // "quant" | "verbal" | "data-insights" | "awa"
  topic           String
  questionType    String   @map("question_type") // "PS" | "DS" | "CR" | "RC" | "SC" | "TPA" | "MSR" | "GI" | "TA"
  difficulty      String   // "easy" | "medium" | "hard" | "700+"

  errorType       String   @map("error_type") // "concept" | "careless" | "time_pressure" | "misread"
  errorDetail     String   @map("error_detail") @db.Text
  correctApproach String?  @map("correct_approach") @db.Text

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([userId, section])
  @@map("error_logs")
}

// ============================================
// PREPWISE — MOCK TESTS
// ============================================

model MockTest {
  id                String   @id @default(cuid())
  userId            String   @map("user_id") @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  takenAt           DateTime @default(now()) @map("taken_at")
  durationMins      Int      @map("duration_mins")

  quantScore        Int?     @map("quant_score") // 60-90 scale
  verbalScore       Int?     @map("verbal_score")
  dataInsightsScore Int?     @map("data_insights_score")
  totalScore        Int?     @map("total_score") // 205-805 scale

  quantAccuracy     Float?   @map("quant_accuracy")
  verbalAccuracy    Float?   @map("verbal_accuracy")
  diAccuracy        Float?   @map("di_accuracy")

  notes             String?  @db.Text

  @@index([userId])
  @@map("mock_tests")
}

// ============================================
// PREPWISE — STUDY JOURNAL
// ============================================

model StudyJournalEntry {
  id              String   @id @default(cuid())
  userId          String   @map("user_id") @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date            DateTime @db.Date // One entry per day
  
  // Daily stats (auto-calculated from sessions)
  totalMinutes    Int      @default(0) @map("total_minutes")
  sessionsCount   Int      @default(0) @map("sessions_count")
  questionsTotal  Int      @default(0) @map("questions_total")
  questionsCorrect Int     @default(0) @map("questions_correct")
  accuracy        Float    @default(0.0)

  // Topics covered today
  topicsCovered   String[] @map("topics_covered")
  sectionsWorked  String[] @map("sections_worked") // "quant" | "verbal" | "data-insights" | "awa"

  // Errors & patterns
  errorsCount     Int      @default(0) @map("errors_count")
  errorTypes      Json     @default("{}") @map("error_types") // {concept: 2, careless: 1, ...}

  // Sam's insight (auto-generated after last session of the day)
  samInsight      String?  @map("sam_insight") @db.Text // "You improved on DS today. Focus on geometry tomorrow."
  
  // Milestones hit today
  milestones      String[] // "First 100 questions", "Quant accuracy > 80%", etc.

  // Mood / self-reflection (optional, user-submitted)
  userNote        String?  @map("user_note") @db.Text
  confidenceLevel Int?     @map("confidence_level") // 1-5 self-rated confidence

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
  @@map("study_journal")
}
